<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Notification Permission for Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Exact Alarm Permission for Android 12+ -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Boot Completion Permission -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Storage Permission for compatibility on API 28 and below -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ExpenseEye">
        <!-- Splash Screen Launcher -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Host Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Register Alarm / Reminder Broadcast Receiver -->
        <receiver
            android:name=".utils.ReminderReceiver"
            android:enabled="true"
            android:exported="false" />

        <!-- Register Boot Receiver -->
        <receiver
            android:name=".utils.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Quick Add Expense Dialog-Activity -->
        <activity
            android:name=".QuickAddExpenseActivity"
            android:theme="@style/Theme.ExpenseEye.TransparentActivity"
            android:windowSoftInputMode="stateAlwaysVisible|adjustNothing"
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- Quick Add Checklist Dialog-Activity -->
        <activity
            android:name=".QuickAddChecklistActivity"
            android:theme="@style/Theme.ExpenseEye.TransparentActivity"
            android:windowSoftInputMode="stateAlwaysVisible|adjustNothing"
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- Category Management Activity -->
        <activity
            android:name=".CategoryManagementActivity"
            android:label="Manage Categories"
            android:theme="@style/Theme.ExpenseEye"
            android:exported="false" />

        <!-- Category Editor Activity -->
        <activity
            android:name=".CategoryEditorActivity"
            android:label="Edit Category"
            android:theme="@style/Theme.ExpenseEye"
            android:exported="false" />

        <activity
            android:name=".ReminderExpensesActivity"
            android:label="Reminder Expenses"
            android:theme="@style/Theme.ExpenseEye"
            android:exported="false" />

        <activity
            android:name=".SmartFeaturesActivity"
            android:label="Smart Features"
            android:theme="@style/Theme.ExpenseEye"
            android:exported="false" />

        <activity
            android:name=".BudgetsActivity"
            android:label="Monthly Budgets"
            android:theme="@style/Theme.ExpenseEye"
            android:exported="false" />



        <!-- Expense Home Screen Widget Provider -->
        <receiver
            android:name=".widget.WidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <!-- RemoteViews Service for Checklist Widget ListView -->
        <service
            android:name=".widget.WidgetChecklistService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.expenseeye.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>