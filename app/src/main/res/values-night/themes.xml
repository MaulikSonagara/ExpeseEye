<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Midnight Calm -->
    <style name="Theme.ExpenseEye.MidnightCalm" parent="Theme.ExpenseEye.Base">
        <item name="colorPrimary">@color/mc_d_primary</item>
        <item name="colorSecondary">@color/mc_d_secondary</item>
        <item name="android:windowBackground">@color/mc_d_background</item>
        <item name="colorSurface">@color/mc_d_surface</item>
        <item name="colorError">@color/mc_d_danger</item>
        <item name="android:textColorPrimary">@color/mc_d_text_primary</item>
        <item name="android:textColorSecondary">@color/mc_d_text_secondary</item>
        <item name="colorOnSurface">@color/mc_d_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/mc_d_text_secondary</item>
        <item name="colorPrimaryContainer">@color/mc_d_divider</item>
        <item name="colorOnPrimaryContainer">@color/mc_d_primary_soft</item>
        <item name="colorSecondaryContainer">@color/mc_d_elevated</item>
        <item name="colorOnSecondaryContainer">@color/mc_d_primary</item>
        <item name="colorOutlineVariant">@color/mc_d_divider</item>
    </style>

