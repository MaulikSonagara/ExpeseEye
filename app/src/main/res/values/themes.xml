<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Midnight Calm -->
    <style name="Theme.ExpenseEye.MidnightCalm" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/mc_l_primary</item>
        <item name="colorSecondary">@color/mc_l_secondary</item>
        <item name="android:windowBackground">@color/mc_l_background</item>
        <item name="colorSurface">@color/mc_l_surface</item>
        <item name="colorError">@color/mc_l_danger</item>
        <item name="android:textColorPrimary">@color/mc_l_text_primary</item>
        <item name="android:textColorSecondary">@color/mc_l_text_secondary</item>
        <item name="colorOnSurface">@color/mc_l_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/mc_l_text_secondary</item>
    </style>

    <!-- Forest Ledger -->
    <style name="Theme.ExpenseEye.ForestLedger" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/fl_l_primary</item>
        <item name="colorSecondary">@color/fl_l_secondary</item>
        <item name="android:windowBackground">@color/fl_l_background</item>
        <item name="colorSurface">@color/fl_l_surface</item>
        <item name="android:textColorPrimary">@color/fl_l_text_primary</item>
        <item name="android:textColorSecondary">@color/fl_l_text_secondary</item>
        <item name="colorOnSurface">@color/fl_l_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/fl_l_text_secondary</item>
    </style>

    <!-- Minimal Sand -->
    <style name="Theme.ExpenseEye.MinimalSand" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ms_l_primary</item>
        <item name="colorSecondary">@color/ms_l_secondary</item>
        <item name="android:windowBackground">@color/ms_l_background</item>
        <item name="colorSurface">@color/ms_l_surface</item>
        <item name="android:textColorPrimary">@color/ms_l_text_primary</item>
        <item name="android:textColorSecondary">@color/ms_l_text_secondary</item>
        <item name="colorOnSurface">@color/ms_l_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/ms_l_text_secondary</item>
    </style>

    <!-- Ocean Ledger -->
    <style name="Theme.ExpenseEye.OceanLedger" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ol_l_primary</item>
        <item name="colorSecondary">@color/ol_l_secondary</item>
        <item name="android:windowBackground">@color/ol_l_background</item>
        <item name="colorSurface">@color/ol_l_surface</item>
        <item name="android:textColorPrimary">@color/ol_l_text_primary</item>
        <item name="android:textColorSecondary">@color/ol_l_text_secondary</item>
        <item name="colorOnSurface">@color/ol_l_text_primary</item>
        <item name="colorOnSurfaceVariant">@color/ol_l_text_secondary</item>
    </style>

    <style name="Theme.ExpenseEye" parent="Theme.ExpenseEye.MidnightCalm" />

    <!-- Transparent style for Quick Add Activity -->
    <style name="Theme.ExpenseEye.TransparentActivity" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <!-- Style for popup card dialog -->
    <style name="Theme.ExpenseEye.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowAnimationStyle">@style/DialogAnimation</item>
    </style>

    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_scale_enter</item>
        <item name="android:windowExitAnimation">@anim/dialog_scale_exit</item>
    </style>
</resources>