<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <LinearLayout
        android:id="@+id/layout_splash_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layout_splash_footer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.42">

        <ImageView
            android:id="@+id/img_splash_logo"
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:src="@drawable/expenseeye3_removebg"
            android:layout_marginBottom="24dp"
            android:contentDescription="@string/splash_logo_description" />

        <TextView
            android:id="@+id/tv_splash_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="30sp"
            android:fontFamily="sans-serif-condensed-medium"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:letterSpacing="0.01" />

        <TextView
            android:id="@+id/tv_splash_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_tagline"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:textColor="#8C97D6"
            android:layout_marginTop="10dp"
            android:letterSpacing="0.04" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_splash_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="56dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progress_splash"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="120dp"
            android:layout_height="3dp"
            android:max="100"
            android:progress="8"
            android:progressDrawable="@drawable/progress_splash_bar"
            android:layout_marginBottom="14dp" />

        <TextView
            android:id="@+id/tv_splash_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_status_loading"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:textColor="#565F8C"
            android:letterSpacing="0.06" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>