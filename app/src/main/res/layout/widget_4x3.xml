<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_glass"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Row 1: Today, Weekly, Monthly Totals -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal">

        <!-- Today -->
        <LinearLayout
            android:id="@+id/layout_widget_main_click"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_widget_card"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_widget_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Weekly -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_widget_card"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WEEKLY"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_widget_amount_week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#5DD6C0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Monthly -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_widget_card"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONTHLY"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_widget_amount_month"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#6C7CFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 2: Payment Stats & Pie Chart -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <!-- Payment Stats -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:background="@drawable/bg_widget_card"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PAYMENT STATS"
                android:textColor="#94A3B8"
                android:textSize="8sp"
                android:textStyle="bold"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tv_widget_pay_cash"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cash: ₹0"
                android:textColor="#F8FAFC"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_widget_pay_upi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPI: ₹0"
                android:textColor="#6C7CFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_widget_pay_card"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Card: ₹0"
                android:textColor="#5DD6C0"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Pie Chart -->
        <LinearLayout
            android:id="@+id/layout_widget_pie_click"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_widget_card"
            android:gravity="center"
            android:padding="2dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_widget_pie"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 4: Checklist Container (2 items) -->
    <LinearLayout
        android:id="@+id/layout_widget_checklist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_widget_card"
        android:orientation="vertical"
        android:padding="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDING CHECKS"
            android:textColor="#94A3B8"
            android:textSize="8sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tv_widget_checklist_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="All caught up! 🎉"
            android:textColor="#64748B"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- ListView for scrolling checklist -->
        <ListView
            android:id="@+id/lv_widget_checklist"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp"
            android:nestedScrollingEnabled="true"
            android:scrollbars="none" />
    </LinearLayout>

    <!-- Row 5: Action Buttons (height 48dp) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btn_widget_add"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_widget_surface"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_add"
                android:tint="#6C7CFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Add Expense"
                android:textColor="#6C7CFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_widget_add_checklist"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_widget_surface"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_checklist"
                android:tint="#5DD6C0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Add Task"
                android:textColor="#5DD6C0"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
