<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <!-- Scrollable main canvas -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="120dp">

            <!-- TOP APP BAR (Height: 64dp, Background: transparent) - Inside ScrollView (Not Sticky) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@android:color/transparent"
                android:paddingHorizontal="16dp">

                <!-- Left Section: Avatar (36dp) + Gap (12dp) + Title -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true">

                    <!-- Circular Avatar (using ShapeableImageView) -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/expenseeye3_removebg"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/CircleImageView" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="ExpenseEye"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?android:attr/textColorPrimary" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Inner padded container holding dashboard contents -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="18dp">

                <!-- GREETING SECTION (24dp below App Bar) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good evening, Alex"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary" />

                    <TextView
                        android:id="@+id/tv_greeting_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Here's a look at your finances today."
                        android:textSize="16sp"
                        android:textColor="?android:attr/textColorSecondary" />
                </LinearLayout>

                <!-- ACTIVE TRIP BANNER -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_active_trip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:visibility="gone"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorPrimary"
                    app:cardBackgroundColor="?attr/colorPrimaryContainer"
                    tools:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_travel"
                            app:tint="?attr/colorPrimary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACTIVE TRIP"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                android:letterSpacing="0.08" />

                            <TextView
                                android:id="@+id/tv_active_trip_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Europe Tour"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnPrimaryContainer" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_active_trip_details"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View"
                            android:textSize="13sp"
                            android:textColor="?attr/colorPrimary"
                            android:paddingHorizontal="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- PRIMARY HERO CARD (28dp below Greeting, Height: ~180dp, Radius: 24dp) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <!-- Top Left: Label -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:text="TOTAL SPENT TODAY"
                                android:textSize="11sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:letterSpacing="0.08"
                                android:textStyle="bold" />


                        </RelativeLayout>

                        <!-- Large Amount Text (42sp, Bold) -->
                        <TextView
                            android:id="@+id/tv_today_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="$142.50"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary" />

                        <!-- vs Average Comparison text -->
                        <TextView
                            android:id="@+id/tv_comparison"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="vs $120.00 average"
                            android:textSize="14sp"
                            android:textColor="?android:attr/textColorSecondary" />

                        <!-- Primary CTA Button (Height: 46dp, Radius: 999dp) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_view_details"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginTop="16dp"
                            android:text="View Details"
                            android:textColor="?attr/colorSurface"
                            android:textSize="14sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="?attr/colorPrimary"
                            app:cornerRadius="999dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- MONTHLY SUMMARY CARD (Height: 160dp, Radius: 22dp, White background) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MONTHLY SUMMARY"
                            android:textSize="11sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:letterSpacing="0.08"
                            android:textStyle="bold" />

                        <!-- Middle Inline Typography -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_marginTop="12dp">

                            <TextView
                                android:id="@+id/tv_month_total"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$2,450"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:id="@+id/tv_month_budget_limit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" / $3,000"
                                android:textSize="15sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:fontFamily="sans-serif-medium" />
                        </LinearLayout>

                        <!-- Progress Bar (Height: 8dp, Radius: full, Filled: primary, Background: outline variant) -->
                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progress_monthly_budget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            app:trackThickness="8dp"
                            app:trackCornerRadius="4dp"
                            app:indicatorColor="?attr/colorPrimary"
                            app:trackColor="?attr/colorOutlineVariant"
                            android:progress="70"
                            android:max="100" />

                        <!-- Bottom Left: Savings Mini Block -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="16dp"
                            android:gravity="center_vertical">

                            <!-- Circular Cyan Icon Background (42dp) -->
                            <FrameLayout
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:background="@drawable/bg_mint_badge"
                                android:backgroundTint="?attr/colorPrimaryContainer">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_cash"
                                    app:tint="?attr/colorPrimary" />
                            </FrameLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="EST. SAVINGS"
                                    android:textSize="10sp"
                                    android:textColor="?android:attr/textColorSecondary"
                                    android:textStyle="bold"
                                    android:letterSpacing="0.05" />

                                <TextView
                                    android:id="@+id/tv_est_savings"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="$550.00"
                                    android:textColor="?attr/colorPrimary"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- BUDGET PROGRESS CARD (Radius: 22dp, Padding: 18dp) -->
                <!-- Dummy tv_budget_header for Java compatibility -->
                <TextView
                    android:id="@+id/tv_budget_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_budget_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    app:cardCornerRadius="22dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:text="Budget Progress"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?android:attr/textColorPrimary" />

                            <TextView
                                android:id="@+id/btn_edit_budgets"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:text="EDIT"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                android:padding="6dp"
                                android:background="?android:attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true" />
                        </RelativeLayout>

                        <!-- Dynamic Budget Rows Container -->
                        <LinearLayout
                            android:id="@+id/layout_budget_container"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- BORROW / OWE CARDS (2 equal width cards, Gap: 14dp, Height: 110dp) -->
                <!-- Kept inside dummy container for backwards compatibility just in case -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_dashboard_borrow_owe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layout_debt_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp"
                    android:visibility="gone">

                    <!-- Owe Card (Left) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_owe"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="7dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:cardBackgroundColor="?attr/colorSurface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="YOU OWE"
                                android:textSize="11sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textStyle="bold"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/tv_dash_owe"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0.00"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorError"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="To others"
                                android:textSize="13sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Owed Card (Right) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_owed"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginStart="7dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="?attr/colorOutlineVariant"
                        app:cardBackgroundColor="?attr/colorSurface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="14dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="YOU ARE OWED"
                                android:textSize="11sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:textStyle="bold"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/tv_dash_owed"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0.00"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="By friends"
                                android:textSize="13sp"
                                android:textColor="?android:attr/textColorSecondary"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- RECENT ACTIVITY CARD (Radius: 24dp, Padding: 18dp) -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:cardBackgroundColor="?attr/colorSurface">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <!-- Header Row -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:text="Recent Activity"
                                android:textSize="20sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?android:attr/textColorPrimary" />

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_menu"
                                app:tint="?android:attr/textColorSecondary"
                                android:contentDescription="Menu" />
                        </RelativeLayout>

                        <!-- RecyclerView for Recent Expenses -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_recent_expenses"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            tools:listitem="@layout/item_expense" />

                        <!-- Empty State View -->
                        <TextView
                            android:id="@+id/tv_no_expenses"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:gravity="center"
                            android:text="No recent expenses logged. Tap + to begin!"
                            android:textColor="?android:attr/textColorSecondary"
                            android:textSize="14sp"
                            android:visibility="gone" />

                        <!-- View All Centered Button -->
                        <TextView
                            android:id="@+id/btn_see_all"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="16dp"
                            android:text="VIEW ALL"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textColor="?attr/colorPrimary"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp"
                            android:background="?android:attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout> <!-- Ends the inner padded LinearLayout -->
        </LinearLayout> <!-- Ends the scrollable container LinearLayout inside NestedScrollView -->
    </androidx.core.widget.NestedScrollView>

    <!-- FLOATING ACTION BUTTON (Size: 62dp, Perfect Circle, Primary Fill) -->
    <!-- Margins positioned to float perfectly above bottom navigation bar -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_expense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="100dp"
        android:src="@drawable/ic_add"
        app:tint="?attr/colorSurface"
        app:backgroundTint="?attr/colorPrimary"
        app:fabCustomSize="62dp"
        app:maxImageSize="30dp"
        app:shapeAppearanceOverlay="@style/CircleImageView"
        app:elevation="4dp" />

    <!-- STICKY HAMBURGER MENU / NOTIFICATION ICON (Floats in CoordinatorLayout) -->
    <ImageButton
        android:id="@+id/btn_hamburger_menu"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_menu"
        android:padding="10dp"
        android:scaleType="fitCenter"
        android:contentDescription="Menu"
        app:tint="?android:attr/textColorPrimary" />

    <!-- Hidden compatibility text views for R.id.tv_week_total and R.id.tv_year_total -->
    <TextView
        android:id="@+id/tv_week_total"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_year_total"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
