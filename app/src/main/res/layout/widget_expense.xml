<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_glass"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical">

    <!-- Left Column: Branding and Today's Spending -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.2"
        android:orientation="vertical"
        android:gravity="start|center_vertical"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tv_widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ExpenseEye"
            android:textColor="#818CF8"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_widget_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹0.00"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_widget_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today's Total"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Right Column: Quick Add Actions -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.8"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Groceries Button -->
        <LinearLayout
            android:id="@+id/btn_widget_groceries"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_widget_button"
                android:padding="10dp"
                android:layout_gravity="center">
                <ImageView
                    android:id="@+id/iv_widget_groceries"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_groceries"
                    android:tint="#FFFFFF"
                    android:contentDescription="Add Groceries" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Groceries"
                android:textColor="#F8FAFC"
                android:textSize="9sp"
                android:layout_marginTop="4dp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Transport Button -->
        <LinearLayout
            android:id="@+id/btn_widget_transport"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_widget_button"
                android:padding="10dp"
                android:layout_gravity="center">
                <ImageView
                    android:id="@+id/iv_widget_transport"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_transport"
                    android:tint="#FFFFFF"
                    android:contentDescription="Add Transport" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Travel"
                android:textColor="#F8FAFC"
                android:textSize="9sp"
                android:layout_marginTop="4dp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Shopping Button -->
        <LinearLayout
            android:id="@+id/btn_widget_shopping"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_widget_button"
                android:padding="10dp"
                android:layout_gravity="center">
                <ImageView
                    android:id="@+id/iv_widget_shopping"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_shopping"
                    android:tint="#FFFFFF"
                    android:contentDescription="Add Shopping" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shopping"
                android:textColor="#F8FAFC"
                android:textSize="9sp"
                android:layout_marginTop="4dp"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- General Add Button -->
        <LinearLayout
            android:id="@+id/btn_widget_add"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_widget_button"
                android:padding="10dp"
                android:layout_gravity="center">
                <ImageView
                    android:id="@+id/iv_widget_add"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_add"
                    android:tint="#818CF8"
                    android:contentDescription="Add Expense" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add New"
                android:textColor="#818CF8"
                android:textSize="9sp"
                android:layout_marginTop="4dp"
                android:singleLine="true"
                android:textStyle="bold"
                android:ellipsize="end" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
