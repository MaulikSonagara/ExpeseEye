<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_glass"
    android:orientation="horizontal"
    android:padding="6dp"
    android:gravity="center_vertical">

    <!-- Today's Total Card (left) -->
    <LinearLayout
        android:id="@+id/layout_widget_main_click"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.2"
        android:background="@drawable/bg_widget_card"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="3dp"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today"
            android:textColor="#94A3B8"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_widget_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹0.00"
            android:textColor="#F8FAFC"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Generic Add Button (middle) -->
    <LinearLayout
        android:id="@+id/btn_widget_add"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/bg_widget_surface"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginStart="5dp"
        android:padding="4dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_add"
            android:tint="#6C7CFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" Add"
            android:textColor="#6C7CFF"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Special Item 1 (right) -->
    <LinearLayout
        android:id="@+id/btn_widget_action_1"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.1"
        android:background="@drawable/bg_widget_surface"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginStart="5dp"
        android:padding="4dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/iv_widget_action_1"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_other"
            android:tint="#5DD6C0" />

        <TextView
            android:id="@+id/tv_widget_action_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" Item 1"
            android:textColor="#5DD6C0"
            android:textSize="10sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
