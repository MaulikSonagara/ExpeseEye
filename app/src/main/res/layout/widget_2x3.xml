<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_glass"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Row 1: Today's and Weekly Totals side-by-side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Today -->
        <LinearLayout
            android:id="@+id/layout_widget_main_click"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:background="@drawable/bg_widget_card"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_widget_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#F8FAFC"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Weekly -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_widget_card"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WEEKLY"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_widget_amount_week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0"
                android:textColor="#5DD6C0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 2: Add buttons (height 48dp) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btn_widget_add"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_widget_surface"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_add"
                android:tint="#6C7CFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Expense"
                android:textColor="#6C7CFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_widget_add_checklist"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_widget_surface"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_checklist"
                android:tint="#5DD6C0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Task"
                android:textColor="#5DD6C0"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 3: Checklist Container -->
    <LinearLayout
        android:id="@+id/layout_widget_checklist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_widget_card"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PENDING CHECKS"
            android:textColor="#94A3B8"
            android:textSize="8sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="4dp" />

        <!-- Checklist Item Empty State -->
        <TextView
            android:id="@+id/tv_widget_checklist_empty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="All caught up! 🎉"
            android:textColor="#64748B"
            android:textSize="11sp"
            android:visibility="gone" />

        <!-- Item 1 -->
        <LinearLayout
            android:id="@+id/layout_widget_checklist_item_1"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="visible">

            <ImageView
                android:id="@+id/cb_widget_checklist_1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_widget_checkbox_blank"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tv_widget_checklist_title_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Item 1"
                android:textColor="#F8FAFC"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_widget_checklist_desc_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="HIGH"
                android:textColor="#F87171"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Item 2 -->
        <LinearLayout
            android:id="@+id/layout_widget_checklist_item_2"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="visible">

            <ImageView
                android:id="@+id/cb_widget_checklist_2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="6dp"
                android:src="@drawable/ic_widget_checkbox_blank"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tv_widget_checklist_title_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Item 2"
                android:textColor="#F8FAFC"
                android:textSize="12sp"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_widget_checklist_desc_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="1 qty"
                android:textColor="#94A3B8"
                android:textSize="9sp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
