<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Record Payment"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:layout_marginBottom="16dp" />

        <!-- Amount -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_pay_amount"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="Payment Amount"
            app:startIconDrawable="@drawable/ic_expenses">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_pay_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Mathematics / Percentage shortcuts -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculate by percentage"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pct_10"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="10%"
                android:textSize="12sp"
                android:padding="4dp"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pct_25"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="25%"
                android:textSize="12sp"
                android:padding="4dp"
                android:layout_marginHorizontal="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pct_50"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="50%"
                android:textSize="12sp"
                android:padding="4dp"
                android:layout_marginHorizontal="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pct_100"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="100%"
                android:textSize="12sp"
                android:padding="4dp"
                android:layout_marginStart="4dp" />

        </LinearLayout>

        <!-- Payment Note -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_pay_note"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Payment Note (e.g. UPI, cash)"
            app:startIconDrawable="@drawable/ic_other">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_pay_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Mirror/Log as Expense Switch -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_pay_log_as_expense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Log payback as Expense"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Expandable Pay Expense Options -->
        <LinearLayout
            android:id="@+id/layout_pay_expense_options"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            android:padding="8dp"
            android:background="?attr/colorOutlineVariant"
            android:backgroundTint="@null">

            <!-- Category Selector -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_pay_category"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="Category">

                <AutoCompleteTextView
                    android:id="@+id/spinner_pay_category"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Payment Method Selector -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_pay_payment_method"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Payment Method">

                <AutoCompleteTextView
                    android:id="@+id/spinner_pay_payment_method"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pay_cancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pay_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Record" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
